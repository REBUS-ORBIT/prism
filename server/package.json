{
  "name": "@prism/server",
  "version": "0.2.2",
  "private": true,
  "description": "PRISM orchestrator: Fastify REST + WS gateway + Postgres + Redis",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "codegen:contracts": "node scripts/codegen-contracts.mjs",
    "validate:contracts": "node scripts/codegen-contracts.mjs"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@fastify/websocket": "^10.0.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "markdown-it": "^14.2.0",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "undici": "^6.19.8",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "@types/ws": "^8.5.12",
    "ajv": "^8.20.0",
    "drizzle-kit": "^0.24.0",
    "eslint": "^9.9.1",
    "form-data": "^4.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
