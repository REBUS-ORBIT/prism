# PRISM Visualiser — UE 5.7 DMX plugin MVR / GDTF import driver
#
# This file is a TEMPLATE rendered per-run by UnrealLauncher.cs's
# LaunchMvrImportAsync. Placeholders ({{RUN_ID}}, {{MVR_PATHS_JSON}},
# {{GDTF_PATHS_JSON}}, {{TARGET_FOLDER}}, {{LEVEL_NAME}}) are substituted
# before the script reaches the editor.
#
# The orchestrator runs this as a SECOND `UnrealEditor-Cmd.exe
# -run=PythonScript` pass, AFTER the Phase E import_orbit.py glTF pass.
# At that point the level already exists; this script imports the lighting
# fixtures + scene on top of the existing geometry and re-saves the level.
#
# Contract with the orchestrator (mirrors the import_orbit.py contract):
#   * Emit exactly one PRISM_VISUALISER_MVR_READY <json> line on success.
#   * Emit exactly one PRISM_VISUALISER_MVR_ERROR <json> line on failure
#     and sys.exit(1).
#   * Every other line is forwarded to the orchestrator's Serilog under
#     the "ue-editor" channel.
#
# DMX plugin API notes (UE 5.7):
#
#   The DMX plugin exposes two import surfaces:
#     1. The Interchange-based DMXMVRImporter / DMXGDTFImporter pipeline.
#     2. The legacy DMXImportFactory / DMXMVRSceneActor.import_mvr_archive
#        path that drives the Asset Tools directly.
#
#   We prefer the factory-based legacy path because it's MORE reliable in
#   headless contexts (no Slate UI prompts, no Interchange "select
#   pipeline" modal). The Interchange path is a future cleanup once the
#   `v1.0.0-ue5.7` template artist has validated the smoke test.
#
#   The artist who lands `v1.0.0-ue5.7` MUST validate these calls against
#   the actual installed UE version and adjust if the import factory class
#   names drift between point releases. Known shape variations:
#     * `DMXImportGDTFFactory` vs `UDMXGDTFImportFactory`
#     * `DMXImportMVRFactory.import_mvr_to_world(world, path)` vs
#       `DMXMVRSceneActor.import_mvr_archive(path)` (instance method on a
#       spawned actor — the fallback we use here).

import json
import sys
import time

import unreal  # noqa: F401 - provided by UE's PythonScriptPlugin

RUN_ID = "{{RUN_ID}}"
MVR_PATHS_JSON = r"""{{MVR_PATHS_JSON}}"""
GDTF_PATHS_JSON = r"""{{GDTF_PATHS_JSON}}"""
TARGET_FOLDER = "{{TARGET_FOLDER}}"
LEVEL_NAME = "{{LEVEL_NAME}}"


def _emit_ready(gdtf_count, mvr_count, elapsed_s):
    payload = {
        "runId": RUN_ID,
        "gdtfCount": int(gdtf_count),
        "mvrCount": int(mvr_count),
        "importDurationMs": int(elapsed_s * 1000),
    }
    print("PRISM_VISUALISER_MVR_READY " + json.dumps(payload), flush=True)


def _emit_error(code, message):
    payload = {"code": code, "message": message}
    print("PRISM_VISUALISER_MVR_ERROR " + json.dumps(payload), flush=True)


def _ensure_directory(target_folder):
    # EditorAssetSubsystem -> EditorAssetLibrary fallback, mirroring
    # import_orbit.py's helper.
    get_editor_subsystem = getattr(unreal, "get_editor_subsystem", None)
    subsystem_class = getattr(unreal, "EditorAssetSubsystem", None)
    editor_asset = None
    if get_editor_subsystem is not None and subsystem_class is not None:
        editor_asset = get_editor_subsystem(subsystem_class)
    if editor_asset is None:
        editor_asset = unreal.EditorAssetLibrary
    if hasattr(editor_asset, "does_directory_exist"):
        if not editor_asset.does_directory_exist(target_folder):
            editor_asset.make_directory(target_folder)
    else:
        editor_asset.make_directory(target_folder)


def _import_gdtf_via_factory(gdtf_path, destination):
    # UE 5.7 DMX plugin exposes the GDTF importer via the legacy
    # AssetImportTask + AssetTools surface. The factory class name has
    # shifted across UE 5.x point releases; tolerate both forms.
    asset_tools = unreal.AssetToolsHelpers.get_asset_tools()
    factory_cls = (
        getattr(unreal, "DMXImportGDTFFactory", None)
        or getattr(unreal, "DMXGDTFImportFactory", None)
        or getattr(unreal, "UDMXGDTFImportFactory", None)
    )
    if factory_cls is None:
        raise RuntimeError(
            "DMX plugin GDTF import factory not found. "
            "Confirm the DMX plugin is enabled in the UE template."
        )
    factory = factory_cls()
    task = unreal.AssetImportTask()
    task.set_editor_property("filename", gdtf_path)
    task.set_editor_property("destination_path", destination)
    task.set_editor_property("replace_existing", True)
    task.set_editor_property("automated", True)
    task.set_editor_property("save", True)
    task.set_editor_property("factory", factory)
    asset_tools.import_asset_tasks([task])
    imported = list(task.get_editor_property("imported_object_paths") or [])
    if not imported:
        unreal.log_warning(
            "GDTF import returned no assets for %s — the plugin may have "
            "rejected the file (older spec version or malformed XML)."
            % gdtf_path
        )
    return imported


def _import_mvr_via_factory(mvr_path, world):
    # UE 5.7's DMX plugin in some point releases exposes a top-level
    # `DMXImportMVRFactory.import_mvr_to_world(world, path)` static. In
    # earlier 5.5 / 5.6 builds the same operation lives on a spawned
    # `DMXMVRSceneActor` instance as `import_mvr_archive(file_path)`.
    # We try the static form first, then fall back to the actor form.
    mvr_factory_cls = (
        getattr(unreal, "DMXImportMVRFactory", None)
        or getattr(unreal, "DMXMVRImportFactory", None)
        or getattr(unreal, "UDMXMVRImportFactory", None)
    )
    if mvr_factory_cls is not None and hasattr(mvr_factory_cls, "import_mvr_to_world"):
        mvr_factory_cls.import_mvr_to_world(world, mvr_path)
        return True

    # Fallback: spawn a DMXMVRSceneActor at origin and ask it to ingest
    # the archive. The actor type has shifted name across versions too.
    actor_cls = (
        getattr(unreal, "DMXMVRSceneActor", None)
        or getattr(unreal, "ADMXMVRSceneActor", None)
    )
    if actor_cls is None:
        raise RuntimeError(
            "DMX plugin MVR import surface not found "
            "(neither DMXImportMVRFactory.import_mvr_to_world nor DMXMVRSceneActor). "
            "Confirm the DMX plugin is enabled in the UE template."
        )

    spawner_subsystem = None
    if hasattr(unreal, "EditorActorSubsystem"):
        spawner_subsystem = unreal.get_editor_subsystem(unreal.EditorActorSubsystem)
    location = unreal.Vector(0.0, 0.0, 0.0)
    rotation = unreal.Rotator(0.0, 0.0, 0.0)
    if spawner_subsystem is not None and hasattr(spawner_subsystem, "spawn_actor_from_class"):
        scene_actor = spawner_subsystem.spawn_actor_from_class(actor_cls, location, rotation)
    else:
        scene_actor = unreal.EditorLevelLibrary.spawn_actor_from_class(
            actor_cls, location, rotation
        )
    if scene_actor is None:
        raise RuntimeError("Could not spawn DMXMVRSceneActor for MVR import.")
    if not hasattr(scene_actor, "import_mvr_archive"):
        raise RuntimeError(
            "Spawned DMXMVRSceneActor has no import_mvr_archive method "
            "(UE 5.7 DMX plugin API surface drifted). "
            "Artist should validate v1.0.0-ue5.7 template against the installed plugin."
        )
    scene_actor.import_mvr_archive(mvr_path)
    return True


def _save_current_level():
    level_subsystem = None
    if hasattr(unreal, "LevelEditorSubsystem"):
        level_subsystem = unreal.get_editor_subsystem(unreal.LevelEditorSubsystem)
    if level_subsystem is not None and hasattr(level_subsystem, "save_current_level"):
        level_subsystem.save_current_level()
        return
    unreal.EditorLevelLibrary.save_current_level()


def _get_editor_world():
    # UE 5.4+ deprecates EditorLevelLibrary.get_editor_world() in favour
    # of UnrealEditorSubsystem.get_editor_world(). Prefer the subsystem
    # when present so we don't trip a deprecation log line.
    if hasattr(unreal, "UnrealEditorSubsystem"):
        editor_subsystem = unreal.get_editor_subsystem(unreal.UnrealEditorSubsystem)
        if editor_subsystem is not None and hasattr(editor_subsystem, "get_editor_world"):
            world = editor_subsystem.get_editor_world()
            if world is not None:
                return world
    return unreal.EditorLevelLibrary.get_editor_world()


def main():
    start = time.time()
    try:
        mvr_paths = json.loads(MVR_PATHS_JSON) if MVR_PATHS_JSON else []
        gdtf_paths = json.loads(GDTF_PATHS_JSON) if GDTF_PATHS_JSON else []

        if not isinstance(mvr_paths, list) or not isinstance(gdtf_paths, list):
            raise RuntimeError(
                "MVR_PATHS_JSON / GDTF_PATHS_JSON must decode to JSON arrays."
            )

        if not mvr_paths and not gdtf_paths:
            # The launcher would normally not have called us if both
            # lists were empty, but stay defensive — emit ready with
            # zero counts and exit clean rather than failing the run.
            _emit_ready(0, 0, time.time() - start)
            sys.exit(0)

        _ensure_directory(TARGET_FOLDER + "/GDTF")

        # Step 1: import GDTF fixtures first. MVR scenes reference these,
        # so the MVR import only succeeds when the fixtures are already
        # in the content browser. The DMX plugin caches the imported
        # fixture set in `/Game/<TARGET_FOLDER>/GDTF/`.
        gdtf_imported = 0
        for gdtf_path in gdtf_paths:
            try:
                _import_gdtf_via_factory(gdtf_path, TARGET_FOLDER + "/GDTF")
                gdtf_imported += 1
            except Exception as gdtf_ex:  # noqa: BLE001
                unreal.log_warning(
                    "GDTF import failed for %s: %s" % (gdtf_path, str(gdtf_ex))
                )
                # Continue with the rest — partial failure is preferable
                # to nuking the whole import on a single bad fixture.

        # Step 2: import MVR scenes against the editor world. Each scene
        # spawns its own actor + dependent GDTF references.
        world = _get_editor_world()
        if world is None and mvr_paths:
            raise RuntimeError("Editor world unavailable; cannot import MVR scene(s).")
        mvr_imported = 0
        for mvr_path in mvr_paths:
            try:
                _import_mvr_via_factory(mvr_path, world)
                mvr_imported += 1
            except Exception as mvr_ex:  # noqa: BLE001
                unreal.log_warning(
                    "MVR import failed for %s: %s" % (mvr_path, str(mvr_ex))
                )

        # Step 3: re-save the level so the spawned MVR actors survive
        # the next editor open. The Phase E pass already created and
        # saved the level once; this re-saves with the new actors.
        if mvr_imported > 0:
            try:
                _save_current_level()
            except Exception as save_ex:  # noqa: BLE001
                unreal.log_warning("save_current_level failed: %s" % str(save_ex))

        elapsed = time.time() - start
        _emit_ready(gdtf_imported, mvr_imported, elapsed)
        sys.exit(0)
    except Exception as ex:  # noqa: BLE001
        _emit_error("mvr_import_failed", str(ex))
        sys.exit(1)


if __name__ == "__main__":
    main()
